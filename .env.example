# Подключение к PostgreSQL.
# Скопируйте этот файл в .env и подставьте свои значения.
#
# Вариант А (прод, Neon/Vercel): одна строка подключения с SSL.
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
#
# Вариант Б (локально): отдельные переменные.
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=school
DB_PORT=5432

# Авторизация администратора (вход в панель)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
AUTH_SECRET=replace_with_a_long_random_string

# Хранилище фото.
# Локально можно не задавать — файлы пишутся в public/uploads.
# В проде (Vercel) подключите Blob-хранилище, токен появится автоматически.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
